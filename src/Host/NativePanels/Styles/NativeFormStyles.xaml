<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="QiTuFieldLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextSecondary}" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontBase}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>

  <Style x:Key="QiTuSectionTitle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextPrimary}" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontMd}" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>

  <Style x:Key="QiTuDescriptionText" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextSecondary}" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontSm}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="20" />
  </Style>

  <Style x:Key="QiTuVerticalOverlayScrollBar" TargetType="ScrollBar">
    <Setter Property="Width" Value="8" />
    <Setter Property="MinWidth" Value="8" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent"
                SnapsToDevicePixels="True">
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageUpCommand"
                              Opacity="0"
                              Focusable="False" />
              </Track.DecreaseRepeatButton>
              <Track.Thumb>
                <Thumb x:Name="Thumb"
                       MinHeight="28">
                  <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                      <Border x:Name="ThumbRoot"
                              Width="4"
                              HorizontalAlignment="Center"
                              Background="{DynamicResource QiTuScrollbarThumb}"
                              CornerRadius="2" />
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter TargetName="ThumbRoot" Property="Width" Value="6" />
                          <Setter TargetName="ThumbRoot" Property="Background" Value="{DynamicResource QiTuScrollbarThumbHover}" />
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Thumb.Template>
                </Thumb>
              </Track.Thumb>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="ScrollBar.PageDownCommand"
                              Opacity="0"
                              Focusable="False" />
              </Track.IncreaseRepeatButton>
            </Track>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuOverlayScrollViewer" TargetType="ScrollViewer">
    <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollViewer">
          <Grid>
            <ScrollContentPresenter
                                    Content="{TemplateBinding Content}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    CanContentScroll="{TemplateBinding CanContentScroll}"
                                    Margin="{TemplateBinding Padding}" />
            <ScrollBar x:Name="PART_VerticalScrollBar"
                       HorizontalAlignment="Right"
                       Maximum="{TemplateBinding ScrollableHeight}"
                       ViewportSize="{TemplateBinding ViewportHeight}"
                       Value="{TemplateBinding VerticalOffset}"
                       Opacity="0"
                       IsHitTestVisible="False"
                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                       Style="{StaticResource QiTuVerticalOverlayScrollBar}" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              <Setter TargetName="PART_VerticalScrollBar" Property="IsHitTestVisible" Value="True" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuTextBox" TargetType="TextBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Background" Value="{DynamicResource QiTuBgInset}" />
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource QiTuBorderDefault}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontBase}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="CaretBrush" Value="{DynamicResource QiTuAccentPrimary}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{DynamicResource QiTuRadiusMd}">
            <ScrollViewer x:Name="PART_ContentHost"
                          Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource QiTuBorderHover}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource QiTuBorderFocus}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.55" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuComboBox" TargetType="ComboBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Background" Value="{DynamicResource QiTuBgInset}" />
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource QiTuBorderDefault}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontBase}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBox">
          <Grid>
            <ToggleButton x:Name="Toggle"
                          Focusable="False"
                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                          ClickMode="Press"
                          Background="{TemplateBinding Background}"
                          Foreground="{TemplateBinding Foreground}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}">
              <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                  <Border x:Name="Root"
                          Background="{TemplateBinding Background}"
                          BorderBrush="{TemplateBinding BorderBrush}"
                          BorderThickness="{TemplateBinding BorderThickness}"
                          CornerRadius="{DynamicResource QiTuRadiusMd}">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="28" />
                      </Grid.ColumnDefinitions>
                      <ContentPresenter Margin="12,0,4,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                      <TextBlock Grid.Column="1"
                                 Text="▼"
                                 FontSize="9"
                                 Foreground="{DynamicResource QiTuTextSecondary}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource QiTuBorderHover}" />
                    </Trigger>
                    <Trigger Property="IsChecked" Value="True">
                      <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource QiTuBorderFocus}" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </ToggleButton.Template>
            </ToggleButton>
            <Popup x:Name="PART_Popup"
                   AllowsTransparency="True"
                   Focusable="False"
                   IsOpen="{TemplateBinding IsDropDownOpen}"
                   Placement="Bottom"
                   PopupAnimation="None">
              <Border MinWidth="{TemplateBinding ActualWidth}"
                      Margin="0,4,0,0"
                      Padding="4"
                      Background="{DynamicResource QiTuBgSurface}"
                      BorderBrush="{DynamicResource QiTuBorderHover}"
                      BorderThickness="1"
                      CornerRadius="{DynamicResource QiTuRadiusMd}">
                <ScrollViewer MaxHeight="180">
                  <ItemsPresenter />
                </ScrollViewer>
              </Border>
            </Popup>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ComboBoxItem">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextPrimary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ComboBoxItem">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  CornerRadius="{DynamicResource QiTuRadiusSm}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource QiTuBgHover}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource QiTuBgActive}" />
              <Setter Property="Foreground" Value="{DynamicResource QiTuAccentPrimary}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuCheckBox" TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource QiTuTextPrimary}" />
    <Setter Property="FontSize" Value="{DynamicResource QiTuFontBase}" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="Box"
                    Width="16"
                    Height="16"
                    Background="{DynamicResource QiTuBgInset}"
                    BorderBrush="{DynamicResource QiTuBorderDefault}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource QiTuRadiusSm}"
                    VerticalAlignment="Center">
              <TextBlock x:Name="Tick"
                         Text="✓"
                         Foreground="{DynamicResource QiTuTextOnAccent}"
                         FontSize="11"
                         FontWeight="Normal"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="Collapsed" />
            </Border>
            <ContentPresenter Grid.Column="1"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource QiTuBorderHover}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Box" Property="Background" Value="{DynamicResource QiTuAccentPrimary}" />
              <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource QiTuAccentPrimary}" />
              <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Box" Property="Opacity" Value="0.5" />
              <Setter Property="Opacity" Value="0.65" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuSwitch" TargetType="CheckBox">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid Width="32"
                Height="18">
            <Border x:Name="Track"
                    Width="32"
                    Height="18"
                    Background="{DynamicResource QiTuBorderHover}"
                    CornerRadius="9" />
            <Ellipse x:Name="Knob"
                     Width="14"
                     Height="14"
                     Margin="2"
                     HorizontalAlignment="Left"
                     Fill="{DynamicResource QiTuTextOnAccent}" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Track" Property="Opacity" Value="0.9" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Track" Property="Background" Value="{DynamicResource QiTuAccentPrimary}" />
              <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Track" Property="Opacity" Value="0.5" />
              <Setter TargetName="Knob" Property="Opacity" Value="0.75" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="QiTuPanelCard" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource QiTuBgSurface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource QiTuBorderDefault}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource QiTuRadiusLg}" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
  </Style>

  <Style x:Key="QiTuStatusTag" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource QiTuBgActive}" />
    <Setter Property="CornerRadius" Value="{DynamicResource QiTuRadiusSm}" />
    <Setter Property="Padding" Value="8,4" />
  </Style>
</ResourceDictionary>
